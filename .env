# Dashboard Title

TITLE="Sono Booking Aswan"



# Dashboard Description

DESCRIPTION="Sono Booking is a system for booking and managing bookings of Aswan Governorate"



# =============================================================================

# LOCAL DEV (active) — IIS Express on :57951

# Run API via Visual Studio "IIS Express" profile, then restart Next.js after edits.

# All three hosts below MUST match (same port, no /wwwroot suffix on NEXT_PUBLIC_*).
# SignalR connects DIRECTLY to hub URLs (not via Next rewrite). CORS on the API
# allows http://localhost:3000 with credentials + access_token query param.

# =============================================================================

# BACK_END="http://localhost:57951/api/v1"

# NEXT_PUBLIC_BACK_END="http://localhost:57951"

# NEXT_PUBLIC_SIGNALR_HUB_URL="http://localhost:57951/api/v1/hubs/chat"

# NEXT_PUBLIC_NOTIFICATION_HUB_URL="http://localhost:57951/api/v1/hubs/notifications"

# NEXT_PUBLIC_VIDEO_HUB_URL="http://localhost:57951/api/v1/hubs/video"



# =============================================================================

# LOCAL DEV — Kestrel (dotnet run profile) — swap with IIS Express block above

# =============================================================================

# BACK_END="http://localhost:5033/api/v1"

# NEXT_PUBLIC_BACK_END="http://localhost:5033"

# NEXT_PUBLIC_SIGNALR_HUB_URL="http://localhost:5033/api/v1/hubs/chat"

# NEXT_PUBLIC_NOTIFICATION_HUB_URL="http://localhost:5033/api/v1/hubs/notifications"

# NEXT_PUBLIC_VIDEO_HUB_URL="http://localhost:5033/api/v1/hubs/video"



# =============================================================================

# PRODUCTION — swap with LOCAL block above when testing against deployed API

# =============================================================================

BACK_END="http://sonobooking.runasp.net/api/v1"

NEXT_PUBLIC_BACK_END="http://sonobooking.runasp.net/wwwroot"

NEXT_PUBLIC_SIGNALR_HUB_URL="http://sonobooking.runasp.net/api/v1/hubs/chat"

NEXT_PUBLIC_NOTIFICATION_HUB_URL="http://sonobooking.runasp.net/api/v1/hubs/notifications"

NEXT_PUBLIC_VIDEO_HUB_URL="http://sonobooking.runasp.net/api/v1/hubs/video"



# Backend Cookies for Auth

# COOKIE_DOMAIN=.sono.net  # only when deployed on *.sono.net; leave unset for Vercel preview / localhost

ACCESS_TOKEN_COOKIE=Acc_Tok_Sono_Booking

# Access token cookie lifetime in SECONDS (604800 = 7 days)

NEXT_PUBLIC_ACCESS_TOKEN_LIFE=604800

NEXT_PUBLIC_REFRESH_TOKEN_COOKIE=Ref_Tok_Sono_Booking

# Refresh token cookie lifetime in SECONDS (2592000 = 30 days)

NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_LIFE=2592000

NEXT_PUBLIC_REFRESH_GUDIE_COOKIE=Ref_Guid_Sono_Booking

# Refresh guide cookie lifetime in SECONDS (2592000 = 30 days)

NEXT_PUBLIC_REFRESH_GUDIE_LIFE=2592000



# Frontend Localization Cookie

NEXT_LOCALE=NEXT_LOCALE



# Default Reset Password

NEXT_PUBLIC_DEF_PASS=123456



